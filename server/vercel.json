{
  "version": 2,
  "builds": [
    {
      "src": "./server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/backup/run?secret=de9ce7ec-cb90-40ac-ad1e-4fcfa2a52a46",
      "schedule": "0 2 * * *"
    }
  ]
}
