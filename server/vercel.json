{
  "version": 2,
  "builds": [
    {
      "src": "./server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/backup/run?secret=a438d176-9b6d-49d1-8b64-42342a1a60b5",
      "schedule": "0 2 * * *"
    }
  ]
}
